<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sprout Shop — Fresh Finds</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,800;1,9..144,300&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #faf6f0;
    --bark: #2c1f14;
    --moss: #3d5a3e;
    --sage: #8aab7f;
    --sun: #e8a430;
    --blush: #f2d9c8;
    --clay: #c4735a;
    --white: #ffffff;
    --shadow: rgba(44,31,20,0.10);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--bark);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--cream);
    border-bottom: 1.5px solid var(--blush);
    padding: 0 5vw;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
    animation: slideDown .5s ease both;
  }
  @keyframes slideDown { from{transform:translateY(-100%);opacity:0} to{transform:translateY(0);opacity:1} }

  .logo {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem; font-weight: 800;
    color: var(--moss);
    letter-spacing: -1px;
    display: flex; align-items: center; gap: 8px;
    cursor: pointer;
  }
  .logo span { color: var(--sun); }

  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-size: .92rem; font-weight: 500; color: var(--bark);
    text-decoration: none; transition: color .2s;
  }
  .nav-links a:hover { color: var(--moss); }

  .nav-actions { display: flex; align-items: center; gap: 1rem; }
  .btn-icon {
    background: none; border: none; cursor: pointer;
    font-size: 1.2rem; color: var(--bark); transition: transform .2s;
    position: relative;
  }
  .btn-icon:hover { transform: scale(1.15); }
  .cart-badge {
    position: absolute; top: -6px; right: -8px;
    background: var(--clay); color: #fff;
    font-size: .65rem; font-weight: 700;
    width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .btn-nav {
    background: var(--moss); color: #fff;
    border: none; border-radius: 999px;
    padding: .45rem 1.1rem; font-size: .88rem; font-weight: 600;
    cursor: pointer; transition: background .2s, transform .15s;
  }
  .btn-nav:hover { background: var(--bark); transform: scale(1.04); }

  /* ── HERO ── */
  .hero {
    min-height: 90vh;
    display: grid; grid-template-columns: 1fr 1fr; align-items: center;
    padding: 6vh 5vw;
    gap: 4rem;
    background: linear-gradient(135deg, var(--cream) 60%, var(--blush) 100%);
    position: relative; overflow: hidden;
    animation: fadeUp .7s .1s ease both;
  }
  @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

  .hero::before {
    content: '';
    position: absolute; right: -80px; top: -80px;
    width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, var(--sage) 0%, transparent 70%);
    opacity: .18; pointer-events: none;
  }

  .hero-text h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    font-weight: 800; line-height: 1.05;
    color: var(--bark);
    margin-bottom: 1.2rem;
  }
  .hero-text h1 em {
    font-style: italic; color: var(--moss);
  }
  .hero-text p {
    font-size: 1.05rem; color: #6a5748; line-height: 1.7;
    max-width: 420px; margin-bottom: 2rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    background: var(--moss); color: #fff;
    border: none; border-radius: 999px;
    padding: .85rem 2rem; font-size: 1rem; font-weight: 600;
    cursor: pointer; transition: all .2s;
    box-shadow: 0 6px 20px rgba(61,90,62,.3);
  }
  .btn-primary:hover { background: var(--bark); transform: translateY(-2px); box-shadow: 0 10px 28px rgba(61,90,62,.35); }
  .btn-outline {
    background: transparent; color: var(--moss);
    border: 2px solid var(--moss); border-radius: 999px;
    padding: .85rem 2rem; font-size: 1rem; font-weight: 600;
    cursor: pointer; transition: all .2s;
  }
  .btn-outline:hover { background: var(--moss); color: #fff; }

  .hero-stats {
    display: flex; gap: 2.5rem; margin-top: 2.5rem;
  }
  .stat-val {
    font-family: 'Fraunces', serif;
    font-size: 2rem; font-weight: 800; color: var(--clay);
  }
  .stat-lbl { font-size: .78rem; color: #8a7060; font-weight: 500; margin-top: 2px; }

  .hero-visual {
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-card-main {
    background: var(--white);
    border-radius: 28px;
    padding: 2.5rem;
    box-shadow: 0 20px 60px var(--shadow);
    max-width: 340px; width: 100%;
    animation: floatCard 4s ease-in-out infinite;
    position: relative; z-index: 2;
  }
  @keyframes floatCard { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
  .hero-card-main .product-emoji { font-size: 5rem; display: block; margin-bottom: 1rem; text-align: center; }
  .hero-card-main h3 { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 700; margin-bottom: .3rem; }
  .hero-card-main .price { font-size: 1.6rem; font-weight: 700; color: var(--clay); }
  .hero-card-main .tag { background: var(--blush); color: var(--clay); font-size: .75rem; font-weight: 600; border-radius: 999px; padding: .2rem .7rem; display: inline-block; margin-bottom: .8rem; }

  .floating-chip {
    position: absolute;
    background: var(--white);
    border-radius: 16px;
    padding: .7rem 1.2rem;
    box-shadow: 0 8px 24px var(--shadow);
    font-size: .82rem; font-weight: 600;
    display: flex; align-items: center; gap: .5rem;
    z-index: 3;
  }
  .chip-1 { top: 5%; left: -20px; animation: floatChip1 3s 1s ease-in-out infinite; }
  .chip-2 { bottom: 10%; right: -10px; animation: floatChip2 3.5s .5s ease-in-out infinite; }
  @keyframes floatChip1 { 0%,100%{transform:translateY(0) rotate(-3deg)} 50%{transform:translateY(-8px) rotate(-3deg)} }
  @keyframes floatChip2 { 0%,100%{transform:translateY(0) rotate(2deg)} 50%{transform:translateY(8px) rotate(2deg)} }

  /* ── CATEGORIES ── */
  .section { padding: 5rem 5vw; }
  .section-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 2.5rem;
  }
  .section-header h2 {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 800;
    line-height: 1.1;
  }
  .section-header h2 em { font-style: italic; color: var(--moss); }
  .link-all { color: var(--moss); font-weight: 600; font-size: .9rem; text-decoration: none; border-bottom: 2px solid var(--sage); padding-bottom: 2px; transition: color .2s; }
  .link-all:hover { color: var(--bark); }

  .categories {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1.2rem;
  }
  .cat-card {
    background: var(--white);
    border-radius: 20px;
    padding: 1.8rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: transform .2s, box-shadow .2s;
    box-shadow: 0 4px 12px var(--shadow);
    border: 2px solid transparent;
  }
  .cat-card:hover { transform: translateY(-6px); box-shadow: 0 14px 30px var(--shadow); border-color: var(--sage); }
  .cat-card.active { border-color: var(--moss); background: var(--moss); color: var(--white); }
  .cat-card .cat-icon { font-size: 2.4rem; display: block; margin-bottom: .7rem; }
  .cat-card .cat-name { font-weight: 600; font-size: .9rem; }
  .cat-card .cat-count { font-size: .75rem; opacity: .7; margin-top: 3px; }

  /* ── PRODUCTS ── */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.6rem;
  }
  .product-card {
    background: var(--white);
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: transform .25s, box-shadow .25s;
    box-shadow: 0 4px 16px var(--shadow);
    position: relative;
  }
  .product-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px var(--shadow); }

  .product-img {
    height: 200px;
    display: flex; align-items: center; justify-content: center;
    font-size: 5rem;
    position: relative;
    overflow: hidden;
  }
  .product-badge {
    position: absolute; top: 12px; left: 12px;
    background: var(--clay); color: #fff;
    font-size: .72rem; font-weight: 700; border-radius: 999px;
    padding: .25rem .7rem;
  }
  .product-badge.new { background: var(--moss); }
  .product-badge.sale { background: var(--sun); color: var(--bark); }
  .wishlist-btn {
    position: absolute; top: 10px; right: 12px;
    background: var(--white); border: none; border-radius: 50%;
    width: 36px; height: 36px; font-size: 1rem;
    cursor: pointer; transition: transform .2s;
    box-shadow: 0 2px 8px var(--shadow);
    display: flex; align-items: center; justify-content: center;
  }
  .wishlist-btn:hover { transform: scale(1.2); }
  .wishlist-btn.active { color: var(--clay); }

  .product-info { padding: 1.3rem; }
  .product-info .category-tag {
    font-size: .72rem; font-weight: 600; color: var(--sage);
    text-transform: uppercase; letter-spacing: .06em;
    margin-bottom: .4rem;
  }
  .product-info h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem; font-weight: 700;
    margin-bottom: .3rem; line-height: 1.3;
  }
  .product-info .rating {
    display: flex; align-items: center; gap: .3rem;
    font-size: .8rem; color: #8a7060; margin-bottom: .7rem;
  }
  .stars { color: var(--sun); letter-spacing: -2px; }
  .price-row {
    display: flex; align-items: center; justify-content: space-between;
  }
  .price-main { font-size: 1.3rem; font-weight: 700; color: var(--bark); }
  .price-old { font-size: .85rem; color: #aaa; text-decoration: line-through; margin-left: .4rem; }
  .add-btn {
    background: var(--moss); color: #fff;
    border: none; border-radius: 999px;
    padding: .45rem 1rem; font-size: .82rem; font-weight: 600;
    cursor: pointer; transition: background .2s, transform .15s;
  }
  .add-btn:hover { background: var(--bark); transform: scale(1.05); }
  .add-btn:active { transform: scale(.97); }

  /* ── BANNER ── */
  .banner {
    margin: 0 5vw;
    background: var(--moss);
    border-radius: 28px;
    padding: 3.5rem 4rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 2rem;
    position: relative; overflow: hidden;
  }
  .banner::before {
    content: ''; position: absolute; right: -60px; top: -60px;
    width: 320px; height: 320px; border-radius: 50%;
    background: rgba(255,255,255,.07); pointer-events: none;
  }
  .banner-text h2 {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 800;
    color: #fff; margin-bottom: .7rem;
  }
  .banner-text p { color: rgba(255,255,255,.8); font-size: 1rem; line-height: 1.6; max-width: 440px; }
  .btn-white {
    background: #fff; color: var(--moss);
    border: none; border-radius: 999px;
    padding: .9rem 2.2rem; font-size: 1rem; font-weight: 700;
    cursor: pointer; white-space: nowrap; transition: transform .2s, box-shadow .2s;
    flex-shrink: 0;
    box-shadow: 0 6px 20px rgba(0,0,0,.18);
  }
  .btn-white:hover { transform: scale(1.05); box-shadow: 0 10px 30px rgba(0,0,0,.22); }

  /* ── FEATURES ── */
  .features {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
    padding: 5rem 5vw;
  }
  .feature-card {
    background: var(--white); border-radius: 20px; padding: 2rem 1.5rem;
    box-shadow: 0 4px 16px var(--shadow); text-align: center;
    transition: transform .2s;
  }
  .feature-card:hover { transform: translateY(-4px); }
  .feature-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .feature-card h4 { font-family: 'Fraunces', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: .4rem; }
  .feature-card p { font-size: .85rem; color: #6a5748; line-height: 1.6; }

  /* ── CART SIDEBAR ── */
  .cart-overlay {
    position: fixed; inset: 0; background: rgba(44,31,20,.4);
    z-index: 200; opacity: 0; pointer-events: none; transition: opacity .3s;
    backdrop-filter: blur(4px);
  }
  .cart-overlay.open { opacity: 1; pointer-events: all; }
  .cart-sidebar {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(400px, 100vw);
    background: var(--white);
    z-index: 201; padding: 2rem;
    transform: translateX(100%); transition: transform .35s cubic-bezier(.4,0,.2,1);
    overflow-y: auto; display: flex; flex-direction: column;
  }
  .cart-sidebar.open { transform: translateX(0); }
  .cart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .cart-header h2 { font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 800; }
  .close-btn { background: var(--cream); border: none; border-radius: 50%; width: 40px; height: 40px; font-size: 1.2rem; cursor: pointer; transition: background .2s; }
  .close-btn:hover { background: var(--blush); }
  .cart-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #8a7060; gap: 1rem; }
  .cart-empty span { font-size: 4rem; }
  .cart-items { flex: 1; display: flex; flex-direction: column; gap: 1rem; }
  .cart-item {
    display: flex; gap: 1rem; align-items: center;
    background: var(--cream); border-radius: 16px; padding: 1rem;
  }
  .cart-item-emoji { font-size: 2.5rem; flex-shrink: 0; }
  .cart-item-info { flex: 1; }
  .cart-item-info h4 { font-weight: 600; font-size: .95rem; margin-bottom: .2rem; }
  .cart-item-info .item-price { color: var(--clay); font-weight: 700; }
  .qty-control { display: flex; align-items: center; gap: .5rem; }
  .qty-btn { background: var(--white); border: 1.5px solid var(--blush); border-radius: 50%; width: 26px; height: 26px; font-size: .9rem; cursor: pointer; transition: background .2s; display: flex; align-items: center; justify-content: center; }
  .qty-btn:hover { background: var(--blush); }
  .qty-val { font-weight: 700; min-width: 20px; text-align: center; }
  .cart-footer { margin-top: 1.5rem; border-top: 2px dashed var(--blush); padding-top: 1.5rem; }
  .cart-total { display: flex; justify-content: space-between; font-size: 1.15rem; font-weight: 700; margin-bottom: 1.2rem; }
  .btn-checkout {
    width: 100%; background: var(--moss); color: #fff;
    border: none; border-radius: 999px;
    padding: 1rem; font-size: 1rem; font-weight: 700;
    cursor: pointer; transition: background .2s;
  }
  .btn-checkout:hover { background: var(--bark); }

  /* ── TOAST ── */
  .toast {
    position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--bark); color: #fff;
    padding: .8rem 1.8rem; border-radius: 999px;
    font-weight: 600; font-size: .9rem;
    opacity: 0; transition: all .35s cubic-bezier(.4,0,.2,1);
    z-index: 300; pointer-events: none;
    display: flex; align-items: center; gap: .5rem;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* ── FOOTER ── */
  footer {
    background: var(--bark); color: rgba(255,255,255,.8);
    padding: 3.5rem 5vw 2rem;
  }
  .footer-top {
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem; margin-bottom: 3rem;
  }
  .footer-brand .logo { color: var(--sage); margin-bottom: 1rem; }
  .footer-brand p { font-size: .9rem; line-height: 1.7; max-width: 280px; }
  .footer-col h4 { font-family: 'Fraunces', serif; font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 1rem; }
  .footer-col a { display: block; color: rgba(255,255,255,.65); font-size: .88rem; text-decoration: none; margin-bottom: .5rem; transition: color .2s; }
  .footer-col a:hover { color: #fff; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,.12); padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; font-size: .82rem; color: rgba(255,255,255,.45); }

  /* ── SEARCH BAR ── */
  .search-wrap {
    position: relative; flex: 1; max-width: 300px;
  }
  .search-wrap input {
    width: 100%; background: var(--blush); border: none; border-radius: 999px;
    padding: .5rem 1rem .5rem 2.4rem;
    font-size: .9rem; font-family: 'DM Sans', sans-serif;
    color: var(--bark); outline: none; transition: box-shadow .2s;
  }
  .search-wrap input:focus { box-shadow: 0 0 0 2px var(--sage); }
  .search-wrap::before {
    content: '🔍'; position: absolute; left: .7rem; top: 50%; transform: translateY(-50%);
    font-size: .9rem; pointer-events: none;
  }

  /* ── RESPONSIVE ── */
  @media(max-width: 800px) {
    .hero { grid-template-columns: 1fr; min-height: auto; padding: 4vh 5vw; }
    .hero-visual { display: none; }
    nav .nav-links, nav .search-wrap { display: none; }
    .footer-top { grid-template-columns: 1fr 1fr; }
    .banner { flex-direction: column; padding: 2.5rem; }
  }
  @media(max-width: 500px) {
    .footer-top { grid-template-columns: 1fr; }
    .hero-stats { flex-wrap: wrap; gap: 1.2rem; }
  }

  /* ── BG PATTERN ── */
  .products-section { position: relative; }
  .products-section::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(var(--blush) 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: .4; pointer-events: none; z-index: 0;
  }
  .products-section > * { position: relative; z-index: 1; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">🌿 <span>Sprout</span>Shop</div>
  <ul class="nav-links">
    <li><a href="#">Home</a></li>
    <li><a href="#">Shop</a></li>
    <li><a href="#">About</a></li>
    <li><a href="#">Blog</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
  <div class="nav-actions">
    <div class="search-wrap">
      <input type="text" placeholder="Search products…" id="searchInput" oninput="filterProducts()">
    </div>
    <button class="btn-icon" title="Wishlist">🤍</button>
    <button class="btn-icon" onclick="toggleCart()" title="Cart">
      🛒<span class="cart-badge" id="cartBadge">0</span>
    </button>
    <button class="btn-nav" onclick="toggleCart()">View Cart</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-text" style="animation: fadeUp .7s .15s both">
    <h1>Shop <em>fresh</em>,<br>live better.</h1>
    <p>Discover hand-picked organic products, artisan goods, and everyday essentials — all in one cheerful, easy-to-browse store.</p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="document.querySelector('.products-section').scrollIntoView({behavior:'smooth'})">Shop Now →</button>
      <button class="btn-outline">Explore Deals</button>
    </div>
    <div class="hero-stats">
      <div><div class="stat-val">500+</div><div class="stat-lbl">Products</div></div>
      <div><div class="stat-val">12K</div><div class="stat-lbl">Happy Shoppers</div></div>
      <div><div class="stat-val">4.9★</div><div class="stat-lbl">Avg Rating</div></div>
    </div>
  </div>
  <div class="hero-visual">
    <div class="floating-chip chip-1">🚚 Free Shipping</div>
    <div class="hero-card-main">
      <span class="product-emoji">🧴</span>
      <div class="tag">Best Seller</div>
      <h3>Lavender Body Oil</h3>
      <div class="price">₹649</div>
      <br>
      <button class="btn-primary" style="width:100%;margin-top:.8rem" onclick="addToCart('Lavender Body Oil', 649, '🧴')">Add to Cart</button>
    </div>
    <div class="floating-chip chip-2">✅ 100% Organic</div>
  </div>
</section>

<!-- CATEGORIES -->
<section class="section">
  <div class="section-header">
    <h2>Shop by <em>Category</em></h2>
    <a href="#" class="link-all">View all →</a>
  </div>
  <div class="categories">
    <div class="cat-card active" onclick="setCategory('All')">
      <span class="cat-icon">🛍️</span>
      <div class="cat-name">
